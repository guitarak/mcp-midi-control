{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "packages/server-all": {
      "entry": ["src/server/index.ts", "src/cli/*.ts"]
    },
    "packages/fractal-midi": {
      "entry": ["src/index.ts", "src/*/index.ts", "src/*/*/index.ts", "test/run-all.ts"]
    },
    "packages/am4": { "entry": ["src/device.ts"] },
    "packages/fractal-gen1": { "entry": ["src/descriptor.ts"] },
    "packages/fractal-gen2": { "entry": ["src/device.ts", "src/tools.ts"] },
    "packages/fractal-gen3": { "entry": ["src/device.ts"] },
    "packages/hydrasynth": { "entry": ["src/device.ts", "src/server.ts"] }
  }
}
