{
  "name": "fractal-midi",
  "version": "0.5.1",
  "description": "Pure-TypeScript codec and parameter dictionaries for Fractal Audio devices (AM4, Axe-Fx II, Axe-Fx III, FM3, FM9, VP4, Axe-Fx Standard/Ultra). No MIDI transport dependency, bring your own.",
  "license": "Apache-2.0",
  "author": "Stephen Staker <stephenstaker@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./am4": {
      "types": "./dist/am4/index.d.ts",
      "default": "./dist/am4/index.js"
    },
    "./gen1": {
      "types": "./dist/gen1/index.d.ts",
      "default": "./dist/gen1/index.js"
    },
    "./gen2/axe-fx-ii": {
      "types": "./dist/gen2/axe-fx-ii/index.d.ts",
      "default": "./dist/gen2/axe-fx-ii/index.js"
    },
    "./gen3/axe-fx-iii": {
      "types": "./dist/gen3/axe-fx-iii/index.d.ts",
      "default": "./dist/gen3/axe-fx-iii/index.js"
    },
    "./gen3/fm3": {
      "types": "./dist/gen3/fm3/index.d.ts",
      "default": "./dist/gen3/fm3/index.js"
    },
    "./gen3/fm9": {
      "types": "./dist/gen3/fm9/index.d.ts",
      "default": "./dist/gen3/fm9/index.js"
    },
    "./gen3/vp4": {
      "types": "./dist/gen3/vp4/index.d.ts",
      "default": "./dist/gen3/vp4/index.js"
    },
    "./catalog/*.json": "./catalog/*.json"
  },
  "files": [
    "dist",
    "catalog",
    "docs/CATALOG-SCHEMA.md",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAndrewStaker/fractal-midi.git"
  },
  "homepage": "https://github.com/TheAndrewStaker/fractal-midi#readme",
  "bugs": {
    "url": "https://github.com/TheAndrewStaker/fractal-midi/issues"
  },
  "keywords": [
    "fractal",
    "fractal-audio",
    "axe-fx",
    "axe-fx-ii",
    "axe-fx-iii",
    "fm3",
    "fm9",
    "vp4",
    "am4",
    "midi",
    "sysex",
    "codec",
    "guitar",
    "amp-modeling"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsx scripts/copy-build-assets.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx test/run-all.ts",
    "catalog:export": "tsx scripts/export-catalog.ts",
    "catalog:check": "tsx scripts/export-catalog.ts --check",
    "preflight": "npm run typecheck && npm test && npm run build && npm run catalog:check"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
