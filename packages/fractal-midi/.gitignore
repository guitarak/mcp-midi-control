# Per-device manuals - vendor PDFs are gitignored to avoid
# re-supplying copyrighted material. The .txt extractions ARE
# committed (derivative work, grep-able). See docs/manuals/README.md.
docs/manuals/*.pdf
docs/devices/*/manuals/*.pdf

# Excel patch listings (vendor data, regenerable)
docs/devices/*/manuals/*.xlsx

